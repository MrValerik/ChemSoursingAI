# ===== ChemSource AI — пример конфигурации =====
# Скопируйте в .env и заполните. Файл .env в git не коммитится.

# --- Приложение ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- База данных (PostgreSQL + pgvector) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chemsource
POSTGRES_USER=chemsource
POSTGRES_PASSWORD=change_me
# Полный DSN (если задан, перекрывает поля выше)
# DATABASE_URL=postgresql+psycopg://chemsource:change_me@localhost:5432/chemsource

# --- Очередь / брокер ---
REDIS_URL=redis://localhost:6379/0

# --- LLM (OpenAI-совместимый эндпоинт, напр. llama-server / vLLM) ---
LLM_BASE_URL=http://127.0.0.1:8080/v1
LLM_MODEL=qwen3-8b
LLM_API_KEY=not-needed-for-local
LLM_TIMEOUT_S=120

# --- PubChem (бесплатный, без ключа) ---
PUBCHEM_BASE_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug

# --- Email-коннектор (IMAP/SMTP) — заполняется на этапе интеграций ---
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# --- WhatsApp Cloud API — заполняется на этапе интеграций ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
